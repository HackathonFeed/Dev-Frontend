GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this frontend is hosted.
APP_URL="MY_APP_URL"

# Production API (Render)
BACKEND_URL="https://hackathonfeed-api.onrender.com"
VITE_API_BASE_URL="https://hackathonfeed-api.onrender.com/api/v1"
