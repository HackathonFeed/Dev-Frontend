# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this frontend is hosted.
APP_URL="MY_APP_URL"

# Express proxy target (server.ts forwards /api/v1 → BACKEND_URL)
BACKEND_URL="http://0.0.0.0:8000"

# Render production: do NOT set VITE_API_* — the browser uses same-origin /api/v1 proxy.
# Local dev only (optional — uncomment to call FastAPI directly without the proxy):
# VITE_API_BASE_URL="http://0.0.0.0:8000/api/v1"
# VITE_API_ORIGIN="http://0.0.0.0:8000"
