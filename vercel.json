{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm ci",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://dev-backend-rho.vercel.app/api/v1/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://dev-backend-rho.vercel.app/uploads/:path*"
    },
    {
      "source": "/health",
      "destination": "https://dev-backend-rho.vercel.app/health"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
